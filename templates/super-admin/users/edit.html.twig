{% extends '../../super-admin.base.html.twig' %}

{% block title %}Modifier l'Utilisateur{% endblock %}

{% block body %}
    <div class="container-fluid">
        <div class="row">
            <div class="col-12">
                <div class="card">
                    <div class="card-header bg-warning text-dark">
                        <h3 class="card-title mb-0">
                            <i class="fas fa-edit me-2"></i>
                            Modifier le super administrateur
                        </h3>
                    </div>
                    <div class="card-body">
                        {{ form_start(form, {'attr': {'class': 'row g-3'}}) }}

                        <!-- Informations personnelles -->
                        <div class="col-md-6">
                            {{ form_label(form.firstname, 'Prénom', {'label_attr': {'class': 'form-label fw-bold'}}) }}
                            {{ form_widget(form.firstname, {'attr': {'class': 'form-control'}}) }}
                            {{ form_errors(form.firstname) }}
                        </div>

                        <div class="col-md-6">
                            {{ form_label(form.lastname, 'Nom', {'label_attr': {'class': 'form-label fw-bold'}}) }}
                            {{ form_widget(form.lastname, {'attr': {'class': 'form-control'}}) }}
                            {{ form_errors(form.lastname) }}
                        </div>

                        <!-- Contact -->
                        <div class="col-md-6">
                            {{ form_label(form.email, 'Email', {'label_attr': {'class': 'form-label fw-bold'}}) }}
                            {{ form_widget(form.email, {'attr': {'class': 'form-control'}}) }}
                            {{ form_errors(form.email) }}
                        </div>

                        <div class="col-md-6">
                            {{ form_label(form.phone, 'Téléphone', {'label_attr': {'class': 'form-label fw-bold'}}) }}
                            {{ form_widget(form.phone, {'attr': {'class': 'form-control'}}) }}
                            {{ form_errors(form.phone) }}
                        </div>

                        <!-- Adresse -->
                        <div class="col-12">
                            {{ form_label(form.address, 'Adresse', {'label_attr': {'class': 'form-label fw-bold'}}) }}
                            {{ form_widget(form.address, {'attr': {'class': 'form-control'}}) }}
                            {{ form_errors(form.address) }}
                        </div>

                        <!-- Mot de passe (optionnel en édition) -->
                        <div class="col-md-6">
                            {{ form_label(form.password, 'Nouveau mot de passe', {'label_attr': {'class': 'form-label fw-bold'}}) }}
                            {{ form_widget(form.password, {'attr': {'class': 'form-control', 'placeholder': 'Laisser vide pour ne pas modifier'}}) }}
                            {{ form_errors(form.password) }}
                            <small class="form-text text-muted">
                                Laisser vide pour conserver le mot de passe actuel.
                            </small>
                        </div>

                        <!-- Actions -->
                        <div class="col-12 mt-4">
                            <button type="submit" class="btn btn-primary">
                                <i class="fas fa-save me-2"></i>Modifier l'utilisateur
                            </button>
                            <a href="{{ path('super-admin.users') }}" class="btn btn-secondary">
                                <i class="fas fa-arrow-left me-2"></i>Retour à la liste
                            </a>
                        </div>

                        {{ form_end(form) }}
                    </div>
                </div>
            </div>
        </div>
    </div>
{% endblock %}
