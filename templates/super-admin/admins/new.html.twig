{% extends 'super-admin.base.html.twig' %}

{% block title %}Nouvel Administrateur{% endblock %}

{% block body %}
    <h1>Créer un nouvel administrateur</h1>

    <div class="card mt-4">
        <div class="card-header bg-primary text-white">
            <h5 class="card-title mb-0">
                <i class="fas fa-user-tie me-2"></i>
                Informations de l'administrateur
            </h5>
        </div>
        <div class="card-body">
            {{ form_start(form, {'attr': {'class': 'row g-3'}}) }}

            <div class="col-md-6">
                {{ form_label(form.firstname, 'Prénom', {'label_attr': {'class': 'form-label fw-bold'}}) }}
                {{ form_widget(form.firstname, {'attr': {'class': 'form-control'}}) }}
                {{ form_errors(form.firstname) }}
            </div>

            <div class="col-md-6">
                {{ form_label(form.lastname, 'Nom', {'label_attr': {'class': 'form-label fw-bold'}}) }}
                {{ form_widget(form.lastname, {'attr': {'class': 'form-control'}}) }}
                {{ form_errors(form.lastname) }}
            </div>

            <div class="col-md-6">
                {{ form_label(form.email, 'Email', {'label_attr': {'class': 'form-label fw-bold'}}) }}
                {{ form_widget(form.email, {'attr': {'class': 'form-control'}}) }}
                {{ form_errors(form.email) }}
            </div>

            <div class="col-md-6">
                {{ form_label(form.password, 'Mot de passe', {'label_attr': {'class': 'form-label fw-bold'}}) }}
                {{ form_widget(form.password, {'attr': {'class': 'form-control'}}) }}
                {{ form_errors(form.password) }}
                <small class="form-text text-muted">Minimum 8 caractères</small>
            </div>

            <div class="col-md-6">
                {{ form_label(form.phone, 'Téléphone', {'label_attr': {'class': 'form-label fw-bold'}}) }}
                {{ form_widget(form.phone, {'attr': {'class': 'form-control'}}) }}
                {{ form_errors(form.phone) }}
            </div>

            <div class="col-md-6">
                {{ form_label(form.structure, 'Structure', {'label_attr': {'class': 'form-label fw-bold'}}) }}
                {{ form_widget(form.structure, {'attr': {'class': 'form-select'}}) }}
                {{ form_errors(form.structure) }}
                <small class="form-text text-muted">Structure assignée à cet administrateur</small>
            </div>

            <div class="col-12">
                {{ form_label(form.address, 'Adresse', {'label_attr': {'class': 'form-label fw-bold'}}) }}
                {{ form_widget(form.address, {'attr': {'class': 'form-control'}}) }}
                {{ form_errors(form.address) }}
            </div>

            <div class="col-12">
                <button type="submit" class="btn btn-success">
                    <i class="fas fa-user-tie me-2"></i> Créer l'administrateur
                </button>
                <a href="{{ path('super-admin.admins') }}" class="btn btn-secondary">
                    <i class="fas fa-arrow-left me-2"></i> Retour à la liste
                </a>
            </div>

            {{ form_end(form) }}
        </div>
    </div>
{% endblock %}
