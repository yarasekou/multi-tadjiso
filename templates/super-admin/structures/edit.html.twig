{% extends 'super-admin.base.html.twig' %}

{% block title %}Modifier la Structure{% endblock %}

{% block body %}
    <h1>Modifier la structure</h1>

    <div class="card mt-4">
        <div class="card-body">
            {% if structure.logo %}
                <div class="mb-3">
                    <label class="form-label">Logo actuel</label>
                    <div>
                        <img src="{{ asset('uploads/logos/' ~ structure.logo) }}" alt="Logo {{ structure.name }}" style="max-width: 200px; height: auto;" class="img-thumbnail">
                    </div>
                </div>
            {% endif %}

            {{ form_start(form, {'attr': {'class': 'row g-3', 'enctype': 'multipart/form-data'}}) }}

            {# Les mêmes champs que new.html.twig #}

            <div class="col-12">
                <button type="submit" class="btn btn-primary">
                    <i class="fas fa-save"></i> Modifier la structure
                </button>
                <a href="{{ path('super-admin.structures') }}" class="btn btn-secondary">
                    <i class="fas fa-arrow-left"></i> Retour à la liste
                </a>
            </div>

            {{ form_end(form) }}
        </div>
    </div>
{% endblock %}
