{% extends 'super-admin.base.html.twig' %}

{% block title %}Nouvelle Structure{% endblock %}

{% block body %}
    <h1>Créer une nouvelle structure</h1>

    <div class="card mt-4">
        <div class="card-body">
            {{ form_start(form, {'attr': {'class': 'row g-3', 'enctype': 'multipart/form-data'}}) }}

            <div class="col-md-6">
                {{ form_label(form.name, 'Nom de la structure', {'label_attr': {'class': 'form-label'}}) }}
                {{ form_widget(form.name, {'attr': {'class': 'form-control'}}) }}
                {{ form_errors(form.name) }}
            </div>

            <div class="col-md-6">
                {{ form_label(form.phone, 'Téléphone', {'label_attr': {'class': 'form-label'}}) }}
                {{ form_widget(form.phone, {'attr': {'class': 'form-control'}}) }}
                {{ form_errors(form.phone) }}
            </div>

            <div class="col-md-6">
                {{ form_label(form.email, 'Email', {'label_attr': {'class': 'form-label'}}) }}
                {{ form_widget(form.email, {'attr': {'class': 'form-control'}}) }}
                {{ form_errors(form.email) }}
            </div>

            <div class="col-md-6">
                {{ form_label(form.website, 'Site web', {'label_attr': {'class': 'form-label'}}) }}
                {{ form_widget(form.website, {'attr': {'class': 'form-control'}}) }}
                {{ form_errors(form.website) }}
            </div>

            <div class="col-md-6">
                {{ form_label(form.address, 'Adresse', {'label_attr': {'class': 'form-label'}}) }}
                {{ form_widget(form.address, {'attr': {'class': 'form-control'}}) }}
                {{ form_errors(form.address) }}
            </div>

            <div class="col-md-6">
                {{ form_label(form.logoFile, 'Logo (Image)', {'label_attr': {'class': 'form-label'}}) }}
                {{ form_widget(form.logoFile, {'attr': {'class': 'form-control'}}) }}
                {{ form_errors(form.logoFile) }}
                <div class="form-text">Formats acceptés: JPG, PNG, GIF, WebP (max. 2Mo)</div>
            </div>

            <div class="col-12">
                {{ form_label(form.description, 'Description', {'label_attr': {'class': 'form-label'}}) }}
                {{ form_widget(form.description, {'attr': {'class': 'form-control', 'rows': 4}}) }}
                {{ form_errors(form.description) }}
            </div>

            <div class="col-12">
                <button type="submit" class="btn btn-success">
                    <i class="fas fa-save"></i> Créer la structure
                </button>
                <a href="{{ path('super-admin.structures') }}" class="btn btn-secondary">
                    <i class="fas fa-arrow-left"></i> Retour à la liste
                </a>
            </div>

            {{ form_end(form) }}
        </div>
    </div>
{% endblock %}
