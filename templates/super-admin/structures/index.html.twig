{% extends 'super-admin.base.html.twig' %}

{% block title %}Gestion des Structures{% endblock %}

{% block body %}
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1>Gestion des Structures</h1>
        <a href="{{ path('super-admin.structures.new') }}" class="btn btn-success">
            <i class="fas fa-plus"></i> Nouvelle Structure
        </a>
    </div>

    {% for message in app.flashes('success') %}
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            {{ message }}
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    {% endfor %}

    {% for message in app.flashes('error') %}
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            {{ message }}
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    {% endfor %}

    <div class="card">
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-striped table-hover">
                    <thead>
                    <tr>
                        <th>ID</th>
                        <th>Nom</th>
                        <th>Email</th>
                        <th>Téléphone</th>
                        <th>Responsable</th>
                        <th>Actions</th>
                    </tr>
                    </thead>
                    <tbody>
                    {% for structure in structures %}
                        <tr>
                            <td>{{ structure.id }}</td>
                            <td>
                                <strong>{{ structure.name }}</strong>
                                {% if structure.description %}
                                    <br><small class="text-muted">{{ structure.description|u.truncate(50, '...') }}</small>
                                {% endif %}
                            </td>
                            <td>{{ structure.email }}</td>
                            <td>{{ structure.phone }}</td>
                            <td>
                                {% if structure.user %}
                                    {{ structure.user.firstname }} {{ structure.user.lastname }}
                                {% else %}
                                    <span class="text-muted">Aucun</span>
                                {% endif %}
                            </td>
                            <td>
                                <div class="btn-group btn-group-sm">
                                    <a href="{{ path('super-admin.structures.edit', {'id': structure.id}) }}"
                                       class="btn btn-outline-primary btn-sm"
                                       title="Modifier">
                                        <i class="fas fa-edit"></i>
                                    </a>
                                    <a href="{{ path('super-admin.structures.show', {'id': structure.id}) }}"
                                       class="btn btn-outline-info btn-sm"
                                       title="Voir détails">
                                        <i class="fas fa-eye"></i>
                                    </a>
                                    <form method="post"
                                          action="{{ path('super-admin.structures.delete', {'id': structure.id}) }}"
                                          onsubmit="return confirm('Êtes-vous sûr de vouloir supprimer cette structure ?');"
                                          class="d-inline">
                                        <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ structure.id) }}">
                                        <button type="submit" class="btn btn-outline-danger btn-sm" title="Supprimer">
                                            <i class="fas fa-trash"></i>
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    {% else %}
                        <tr>
                            <td colspan="7" class="text-center text-muted">Aucune structure trouvée</td>
                        </tr>
                    {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    </div>
{% endblock %}
