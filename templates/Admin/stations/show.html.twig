{% extends 'admin.base.html.twig' %}

{% block title %}Détails de la Station - {{ station.name }}{% endblock %}

{% block page_title %}Détails de la Station{% endblock %}

{% block breadcrumb %}
    <li class="breadcrumb-item">
        <a href="{{ path('admin.dashboard') }}">Dashboard</a>
    </li>
    <li class="breadcrumb-item">
        <a href="{{ path('admin.stations') }}">Stations</a>
    </li>
    <li class="breadcrumb-item active">{{ station.name }}</li>
{% endblock %}

{% block body %}
    <div class="container-fluid">
        <!-- En-tête -->
        <div class="d-flex justify-content-between align-items-center mb-4">
            <div>
                <h1 class="h3 mb-0 text-uppercase">{{ station.name }}</h1>
                <p class="text-muted mb-0">Détails complets de la station</p>
            </div>
            <div class="btn-group">
                <a href="{{ path('admin.stations') }}" class="btn btn-outline-secondary">
                    <i class="fas fa-arrow-left me-1"></i> Retour
                </a>
                <a href="{{ path('admin.stations.edit', {'id': station.id}) }}" class="btn btn-primary">
                    <i class="fas fa-edit me-1"></i> Modifier
                </a>
            </div>
        </div>

        <!-- Messages flash -->
        {% for message in app.flashes('success') %}
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                <i class="fas fa-check-circle me-2"></i>
                {{ message }}
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        {% endfor %}

        {% for message in app.flashes('error') %}
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                <i class="fas fa-exclamation-triangle me-2"></i>
                {{ message }}
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        {% endfor %}

        <div class="row">
            <div class="col-md-12">
                <div class="card mb-4">
                    <div class="card-header bg-primary text-white">
                        <h5 class="card-title mb-0">
                            <i class="fas fa-info-circle me-2"></i>
                            Informations générales
                        </h5>
                    </div>
                    <div class="card-body">
                        <div class="row">
                            <div class="col-md-6">
                                <table class="table table-borderless">
                                    <tr>
                                        <th class="w-40">Nom :</th>
                                        <td class="fw-bold text-primary">{{ station.name }}</td>
                                    </tr>
                                    <tr>
                                        <th>Adresse :</th>
                                        <td>
                                            <i class="fas fa-map-marker-alt me-1 text-muted"></i>
                                            {{ station.address }}
                                        </td>
                                    </tr>
                                </table>
                            </div>
                            <div class="col-md-6">
                                <table class="table table-borderless">
                                    <tr>
                                        <th>Téléphone :</th>
                                        <td>
                                            {% if station.phone %}
                                                <i class="fas fa-phone me-1 text-muted"></i>
                                                {{ station.phone }}
                                            {% else %}
                                                <span class="text-muted">Non renseigné</span>
                                            {% endif %}
                                        </td>
                                    </tr>
                                    <tr>
                                        <th>Date création :</th>
                                        <td>{{ station.createdAt|date('d/m/Y H:i') }}</td>
                                    </tr>
                                </table>
                            </div>
                        </div>

                        <!-- Description -->
                        {% if station.description %}
                            <div class="mt-4 p-3 bg-light rounded">
                                <h6 class="text-primary">
                                    <i class="fas fa-file-alt me-2"></i>Description :
                                </h6>
                                <p class="mb-0 text-dark">{{ station.description }}</p>
                            </div>
                        {% endif %}
                    </div>
                </div>
            </div>

            <div class="col-md-12">
                <div class="card mb-4">
                    <div class="card-header bg-success text-white">
                        <h5 class="card-title mb-0">
                            <i class="fas fa-gas-pump me-2"></i>
                            Les carburants disponibles .........................
                        </h5>
                    </div>
                    <div class="card-body">
                        {% if station.typeCarburants is defined and station.typeCarburants|length > 0 %}
                            <div class="table-responsive">
                                <table class="table table-striped table-hover">
                                    <thead class="table-dark">
                                    <tr>
                                        <th>Nom du carburant</th>
                                        <th>Prix unitaire</th>
                                        <th>Disponibilité</th>
                                    </tr>
                                    </thead>
                                    <tbody>
                                    {% for carburant in station.typeCarburants %}
                                        <tr>
                                            <td>
                                                <div class="d-flex align-items-center">
                                                    <div class="avatar-circle-sm bg-info text-white me-3">
                                                        <i class="fas fa-fire"></i>
                                                    </div>
                                                    <div>
                                                        <strong>{{ carburant.name }}</strong>
                                                    </div>
                                                </div>
                                            </td>
                                            <td>
                                                    <span class="fw-bold text-success">
                                                        {{ carburant.unitPrice|number_format(0, ',', ' ') }} FCFA
                                                    </span>
                                                <br>
                                                <small class="text-muted">par litre</small>
                                            </td>
                                            <td>
                                                    <span class="badge bg-success">
                                                        <i class="fas fa-check me-1"></i>Disponible
                                                    </span>
                                            </td>
                                        </tr>
                                    {% endfor %}
                                    </tbody>
                                </table>
                            </div>

                            <!-- Résumé -->
                            <div class="mt-3 p-3 bg-light rounded">
                                <div class="row text-center">
                                    <div class="col-md-4">
                                        <h4 class="text-primary mb-0">{{ station.typeCarburants|length }}</h4>
                                        <small class="text-muted">Types de carburant</small>
                                    </div>
                                    <div class="col-md-4">
                                        <h4 class="text-success mb-0">
                                            {% set totalPrice = 0 %}
                                            {% for carburant in station.typeCarburants %}
                                                {% set totalPrice = totalPrice + carburant.unitPrice %}
                                            {% endfor %}
                                            {{ (totalPrice / station.typeCarburants|length)|number_format(0, ',', ' ') }}
                                        </h4>
                                        <small class="text-muted">Prix moyen (FCFA)</small>
                                    </div>
                                    <div class="col-md-4">
                                        <h4 class="text-info mb-0">
                                            {% set minPrice = null %}
                                            {% for carburant in station.typeCarburants %}
                                                {% if minPrice is null or carburant.unitPrice < minPrice %}
                                                    {% set minPrice = carburant.unitPrice %}
                                                {% endif %}
                                            {% endfor %}
                                            {{ minPrice|number_format(0, ',', ' ') }}
                                        </h4>
                                        <small class="text-muted">Prix minimum (FCFA)</small>
                                    </div>
                                </div>
                            </div>
                        {% else %}
                            <div class="text-center py-4">
                                <i class="fas fa-gas-pump fa-3x text-muted mb-3"></i>
                                <h5 class="text-muted">Aucun carburant disponible</h5>
                                <p class="text-muted">Cette station ne propose actuellement aucun type de carburant.</p>
                                <a href="{{ path('admin.stations.edit', {'id': station.id}) }}" class="btn btn-primary">
                                    <i class="fas fa-plus me-1"></i> Ajouter des carburants
                                </a>
                            </div>
                        {% endif %}
                    </div>
                </div>
            </div>

            <!-- Actions rapides -->
            <div class="col-md-12">
                <div class="card">
                    <div class="card-header">
                        <h5 class="card-title mb-0">
                            <i class="fas fa-cogs me-2"></i>
                            Actions
                        </h5>
                    </div>
                    <div class="card-body">
                        <div class="row">
                            <div class="col-md-6">
                                <div class="d-grid gap-2">
                                    <a href="{{ path('admin.stations.edit', {'id': station.id}) }}"
                                       class="btn btn-outline-primary">
                                        <i class="fas fa-edit me-1"></i> Modifier la station
                                    </a>
                                    <a href="{{ path('admin.stations') }}"
                                       class="btn btn-outline-info">
                                        <i class="fas fa-list me-1"></i> Retour à la liste
                                    </a>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="d-grid gap-2">
                                    <form method="post"
                                          action="{{ path('admin.stations.delete', {'id': station.id}) }}"
                                          onsubmit="return confirm('Êtes-vous sûr de vouloir supprimer cette station ? Cette action est irréversible.');"
                                          class="d-grid">
                                        <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ station.id) }}">
                                        <button type="submit" class="btn btn-outline-danger">
                                            <i class="fas fa-trash me-1"></i> Supprimer la station
                                        </button>
                                    </form>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <style>
        .avatar-circle-sm {
            width: 40px;
            height: 40px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 0.9rem;
        }
        .table th {
            border-top: none;
            font-weight: 600;
        }
    </style>
{% endblock %}
