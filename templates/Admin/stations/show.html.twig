{% extends 'admin.base.html.twig' %}

{% block title %}Détails de la Station {% endblock %}

{% block page_title %}Détails de la Station{% endblock %}

{% block breadcrumb %}
    <li class="breadcrumb-item">
        <a href="{{ path('admin.dashboard') }}">Dashboard</a>
    </li>
    <li class="breadcrumb-item">
        <a href="{{ path('admin.stations') }}">Stations</a>
    </li>
    <li class="breadcrumb-item active">{{ station.name }}</li>
{% endblock %}

{% block body %}
    <div class="container-fluid">
        <!-- En-tête -->
        <div class="d-flex justify-content-between align-items-center mb-4">
            <div>
                <h1 class="h3 mb-0 text-uppercase">{{ station.name }}</h1>
                <p class="text-muted mb-0">Détails complets de la station</p>
            </div>
            <div class="btn-group">
                <a href="{{ path('admin.stations') }}" class="btn btn-outline-secondary">
                    <i class="fas fa-arrow-left me-1"></i> Retour
                </a>
                <a href="{{ path('admin.stations.edit', {'id': station.id}) }}" class="btn btn-primary">
                    <i class="fas fa-edit me-1"></i> Modifier
                </a>
            </div>
        </div>

        <!-- Messages flash -->
        {% for message in app.flashes('success') %}
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                <i class="fas fa-check-circle me-2"></i>
                {{ message }}
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        {% endfor %}

        {% for message in app.flashes('error') %}
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                <i class="fas fa-exclamation-triangle me-2"></i>
                {{ message }}
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        {% endfor %}
        <div class="col-md-12">
            <div class="card mb-4">
                <div class="card-header bg-primary text-white">
                    <h5 class="card-title mb-0">
                        <i class="fas fa-info-circle me-2"></i>
                        Informations générales
                    </h5>
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-6">
                            <table class="table table-borderless">
                                <tr>
                                    <th class="w-40">Nom :</th>
                                    <td class="fw-bold text-primary">{{ station.name }}</td>
                                </tr>
                                <tr>
                                    <th>Adresse :</th>
                                    <td>
                                        <i class="fas fa-map-marker-alt me-1 text-muted"></i>
                                        {{ station.address }}
                                    </td>
                                </tr>
                            </table>
                        </div>
                        <div class="col-md-6">
                            <table class="table table-borderless">
                                <tr>
                                    <th>Téléphone :</th>
                                    <td>
                                        {% if station.phone %}
                                            <i class="fas fa-phone me-1 text-muted"></i>
                                            {{ station.phone }}
                                        {% else %}
                                            <span class="text-muted">Non renseigné</span>
                                        {% endif %}
                                    </td>
                                </tr>
                                <tr>
                                    <th>Date création :</th>
                                    <td>{{ station.createdAt|date('d/m/Y H:i') }}</td>
                                </tr>
                            </table>
                        </div>
                        <!-- Description -->
                        {% if station.description %}
                            <div class="mt-4 p-3 bg-light rounded">
                                <h6 class="text-primary">
                                    <i class="fas fa-file-alt me-2"></i>Description :
                                </h6>
                                <p class="mb-0 text-dark">{{ station.description }}</p>
                            </div>
                        {% endif %}
                    </div>
                </div>
            </div>
            <!-- Sidebar - Actions rapides -->
        </div>
        <div class="d-grid gap-2">
            <a href="{{ path('admin.stations.edit', {'id': station.id}) }}"
               class="btn btn-outline-primary">
                <i class="fas fa-edit me-1"></i> Modifier
            </a>
            <form method="post"
                  action="{{ path('admin.stations.delete', {'id': station.id}) }}"
                  onsubmit="return confirm('Êtes-vous sûr de vouloir supprimer cette station ?');"
                  class="d-grid">
                <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ station.id) }}">
                <button type="submit" class="btn btn-outline-danger">
                    <i class="fas fa-trash me-1"></i> Supprimer
                </button>
            </form>
        </div>

    </div>
{% endblock %}
