{% extends 'layouts/admin.dashboard.html.twig' %}

{% block title %}Détails de la Structure - {{ structure.name }}{% endblock %}

{% block page_title %}Détails de la Structure{% endblock %}

{% block breadcrumb %}
    <li class="breadcrumb-item">
        <a href="{{ path('admin.dashboard') }}">Dashboard</a>
    </li>
    <li class="breadcrumb-item active">{{ structure.name }}</li>
{% endblock %}

{% block body %}
    <div class="container-fluid">
        <!-- En-tête -->
        <div class="d-flex justify-content-between align-items-center mb-4">
            <div>
                <h1 class="h3 mb-0 text-uppercase">{{ structure.name }}</h1>
                <p class="text-muted mb-0">Détails complets de votre structure</p>
            </div>
            <div class="btn-group">
                <a href="{{ path('admin.dashboard') }}" class="btn btn-outline-secondary">
                    <i class="fas fa-arrow-left me-1"></i> Retour
                </a>
                <a href="#" class="btn btn-primary">
                    <i class="fas fa-edit me-1"></i> Modifier
                </a>
            </div>
        </div>

        <!-- Messages flash -->
        {% for message in app.flashes('success') %}
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                <i class="fas fa-check-circle me-2"></i>
                {{ message }}
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        {% endfor %}

        {% for message in app.flashes('error') %}
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                <i class="fas fa-exclamation-triangle me-2"></i>
                {{ message }}
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        {% endfor %}

        <div class="row">
            <!-- Informations principales -->
            <div class="col-lg-8">
                <div class="card mb-4">
                    <div class="card-header bg-primary text-white">
                        <h5 class="card-title mb-0">
                            <i class="fas fa-info-circle me-2"></i>
                            Informations générales
                        </h5>
                    </div>
                    <div class="card-body">
                        <div class="row">
                            <div class="col-md-6">
                                <table class="table table-borderless">
                                    <tr>
                                        <th class="w-40">Nom :</th>
                                        <td class="fw-bold text-primary">{{ structure.name }}</td>
                                    </tr>
                                    <tr>
                                        <th>Email :</th>
                                        <td>
                                            <a href="mailto:{{ structure.email }}" class="text-decoration-none">
                                                <i class="fas fa-envelope me-1"></i>
                                                {{ structure.email }}
                                            </a>
                                        </td>
                                    </tr>
                                    <tr>
                                        <th>Site web :</th>
                                        <td>
                                            {% if structure.website %}
                                                <a href="{{ structure.website }}" target="_blank" class="text-decoration-none">
                                                    <i class="fas fa-globe me-1"></i>
                                                    {{ structure.website }}
                                                </a>
                                            {% else %}
                                                <span class="text-muted">Non renseigné</span>
                                            {% endif %}
                                        </td>
                                    </tr>
                                </table>
                            </div>
                            <div class="col-md-6">
                                <table class="table table-borderless">
                                    <tr>
                                        <th class="w-40">Téléphone :</th>
                                        <td>
                                            <i class="fas fa-phone me-1 text-muted"></i>
                                            {{ structure.phone }}
                                        </td>
                                    </tr>
                                    <tr>
                                        <th>Adresse :</th>
                                        <td>
                                            <i class="fas fa-map-marker-alt me-1 text-muted"></i>
                                            {{ structure.address }}
                                        </td>
                                    </tr>
                                    <tr>
                                        <th>Statut :</th>
                                        <td>
                                            {% if structure %}
                                                <span class="badge bg-success fs-6">
                                                <i class="fas fa-check me-1"></i>Activée
                                            </span>
                                            {% else %}
                                                <span class="badge bg-danger fs-6">
                                                <i class="fas fa-times me-1"></i>Désactivée
                                            </span>
                                            {% endif %}
                                        </td>
                                    </tr>
                                </table>
                            </div>
                        </div>

                        <!-- Description -->
                        {% if structure.description %}
                            <div class="mt-4 p-3 bg-light rounded">
                                <h6 class="text-primary">
                                    <i class="fas fa-file-alt me-2"></i>Description :
                                </h6>
                                <p class="mb-0 text-dark">{{ structure.description }}</p>
                            </div>
                        {% endif %}
                    </div>
                </div>

                <!-- Informations de l'administrateur -->
                <div class="card">
                    <div class="card-header bg-info text-white">
                        <h5 class="card-title mb-0">
                            <i class="fas fa-user-shield me-2"></i>
                            Administrateur de la structure
                        </h5>
                    </div>
                    <div class="card-body">
                        {% if admin_user %}
                            <div class="row align-items-center">
                                <div class="col-md-2 text-center">
                                    <div class="avatar-circle bg-primary text-white">
                                    <span class="avatar-text">
                                        {{ admin_user.firstname|first|upper }}{{ admin_user.lastname|first|upper }}
                                    </span>
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <h5 class="mb-1">{{ admin_user.firstname }} {{ admin_user.lastname }}</h5>
                                    <p class="mb-1 text-muted">
                                        <i class="fas fa-envelope me-1"></i>
                                        {{ admin_user.email }}
                                    </p>
                                    <p class="mb-1 text-muted">
                                        <i class="fas fa-phone me-1"></i>
                                        {{ admin_user.phone ?? 'Non renseigné' }}
                                    </p>
                                    <p class="mb-0 text-muted">
                                        <i class="fas fa-map-marker-alt me-1"></i>
                                        {{ admin_user.address ?? 'Non renseignée' }}
                                    </p>
                                </div>
                                <div class="col-md-4 text-end">
                                <span class="badge bg-primary fs-6 p-2">
                                    <i class="fas fa-star me-1"></i>Niveau {{ admin_user.level }}
                                </span>
                                    <div class="mt-2">
                                        {% if admin_user.enable %}
                                            <span class="badge bg-success">Compte actif</span>
                                        {% else %}
                                            <span class="badge bg-danger">Compte inactif</span>
                                        {% endif %}
                                    </div>
                                </div>
                            </div>
                        {% else %}
                            <div class="text-center text-muted py-4">
                                <i class="fas fa-user-times fa-3x mb-3"></i>
                                <h5>Aucun administrateur assigné</h5>
                                <p class="mb-0">Cette structure n'a pas d'administrateur assigné.</p>
                            </div>
                        {% endif %}
                    </div>
                </div>
            </div>

            <!-- Sidebar - Actions rapides -->
            <div class="col-lg-4">
                <!-- Actions rapides -->
                <div class="card mb-4">
                    <div class="card-header bg-dark text-white">
                        <h6 class="card-title mb-0">
                            <i class="fas fa-bolt me-1"></i>Actions rapides
                        </h6>
                    </div>
                    <div class="card-body">
                        <div class="d-grid gap-2">
                            <a href="#" class="btn btn-outline-primary">
                                <i class="fas fa-edit me-1"></i> Modifier la structure
                            </a>



                            <a href="#" class="btn btn-outline-info">
                                <i class="fas fa-chart-bar me-1"></i> Voir les statistiques
                            </a>
                        </div>
                    </div>
                </div>

                <!-- Informations techniques -->
                <div class="card">
                    <div class="card-header">
                        <h6 class="card-title mb-0">
                            <i class="fas fa-cogs me-1"></i>Informations techniques
                        </h6>
                    </div>
                    <div class="card-body">
                        <table class="table table-sm table-borderless">
                            <tr>
                                <th><i class="fas fa-hashtag me-1 text-muted"></i>ID :</th>
                                <td>#{{ structure.id }}</td>
                            </tr>
                            <tr>
                                <th><i class="fas fa-calendar-plus me-1 text-muted"></i>Créée le :</th>
                                <td>{{ structure.createdAt|date('d/m/Y à H:i') }}</td>
                            </tr>
                            <tr>
                                <th><i class="fas fa-calendar-check me-1 text-muted"></i>Modifiée le :</th>
                                <td>
                                    {% if structure.updatedAt %}
                                        {{ structure.updatedAt|date('d/m/Y à H:i') }}
                                    {% else %}
                                        <span class="text-muted">Jamais modifiée</span>
                                    {% endif %}
                                </td>
                            </tr>
                        </table>
                    </div>
                </div>

                <!-- Logo de la structure -->
                {% if structure.logo %}
                    <div class="card mt-4">
                        <div class="card-header">
                            <h6 class="card-title mb-0">
                                <i class="fas fa-image me-1"></i>Logo
                            </h6>
                        </div>
                        <div class="card-body text-center">
                            <img src="{{ asset('uploads/logos/' ~ structure.logo) }}"
                                 alt="Logo {{ structure.name }}"
                                 class="img-fluid rounded"
                                 style="max-height: 150px;">
                        </div>
                    </div>
                {% endif %}
            </div>
        </div>
    </div>

    <style>
        .avatar-circle {
            width: 80px;
            height: 80px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: bold;
            font-size: 1.5rem;
        }
        .avatar-text {
            line-height: 1;
        }
        .table-borderless th {
            width: 40%;
        }
    </style>
{% endblock %}
