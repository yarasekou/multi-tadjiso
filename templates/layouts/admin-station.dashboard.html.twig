{% extends 'admin-station.base.html.twig' %}

{% block title %}Dashboard — {{ station.name }}{% endblock %}

{% block body %}
    <div class="container mt-4">

        <!-- HEADER -->
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h3 class="fw-bold mb-0">
                <i class="fas fa-gas-pump text-primary me-2"></i>
                Dashboard — <span class="text-dark">{{ station.name }}</span>
            </h3>

            <a href="{{ path('admin.stations') }}" class="btn btn-outline-secondary btn-sm">
                <i class="fas fa-arrow-left me-1"></i> Retour
            </a>
        </div>

        <!-- CARDS -->
        <div class="row g-4">

            <!-- Pompes -->
            <div class="col-md-4">
                <div class="card shadow-sm border-0 card-hover">
                    <div class="card-body text-center">
                        <div class="icon-circle bg-primary bg-opacity-10 text-primary mb-3">
                            <i class="fas fa-gas-pump fa-2x"></i>
                        </div>
                        <h5 class="card-title fw-bold">Pompes</h5>
                        <p class="display-5 fw-bold text-primary mb-3">{{ station.pompes|length }}</p>
                        <a href="{{ path('admin.station.pompes', {id: station.id}) }}" class="btn btn-primary btn-sm">
                            Voir détails <i class="fas fa-arrow-right ms-1"></i>
                        </a>
                    </div>
                </div>
            </div>

            <!-- Types de Carburants -->
            <div class="col-md-4">
                <div class="card shadow-sm border-0 card-hover">
                    <div class="card-body text-center">
                        <div class="icon-circle bg-success bg-opacity-10 text-success mb-3">
                            <i class="fas fa-oil-can fa-2x"></i>
                        </div>
                        <h5 class="card-title fw-bold">Types de carburants</h5>
                        <p class="display-5 fw-bold text-success mb-3">{{ station.typeCarburants|length }}</p>
                        <a href="#" class="btn btn-success btn-sm disabled">
                            Gestion <i class="fas fa-wrench ms-1"></i>
                        </a>
                    </div>
                </div>
            </div>

            <!-- Cuves -->
            <div class="col-md-4">
                <div class="card shadow-sm border-0 card-hover">
                    <div class="card-body text-center">
                        <div class="icon-circle bg-warning bg-opacity-10 text-warning mb-3">
                            <i class="fas fa-database fa-2x"></i>
                        </div>
                        <h5 class="card-title fw-bold">Cuves</h5>
                        <p class="display-5 fw-bold text-warning mb-3">{{ station.cuves|length }}</p>
                        <a href="{{ path('admin.station.cuves', {id: station.id}) }}" class="btn btn-warning btn-sm text-white">
                            Voir détails <i class="fas fa-arrow-right ms-1"></i>
                        </a>
                    </div>
                </div>
            </div>

        </div>

    </div>

    <style>
        .card-hover {
            transition: transform .2s, box-shadow .2s;
        }
        .card-hover:hover {
            transform: translateY(-5px);
            box-shadow: 0 0.75rem 1.5rem rgba(0,0,0,0.1);
        }
        .icon-circle {
            width: 70px;
            height: 70px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto;
        }
    </style>
{% endblock %}
