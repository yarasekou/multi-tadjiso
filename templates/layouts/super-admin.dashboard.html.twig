{% extends 'super-admin.base.html.twig' %}

{% block title %}Tableau de Bord{% endblock %}

{% block page_title %}Tableau de Bord{% endblock %}
{% block breadcrumb %}Dashboard{% endblock %}

{% block body %}
    <div class="container-fluid">
        <!-- Bienvenue -->
        <div class="row mb-4">
            <div class="col-12">
                <div class="card bg-gradient-primary text-white">
                    <div class="card-body">
                        <div class="row align-items-center">
                            <div class="col-md-8">
                                <h2 class="mb-1">Bienvenue, {{ user.firstname }} {{ user.lastname }} !</h2>
                                <p class="mb-0 opacity-75">
                                    <i class="fas fa-user-shield me-1"></i>
                                    Rôles : {{ user.roles|join(', ') }}
                                </p>
                            </div>
                            <div class="col-md-4 text-end">
                                <div class="avatar-lg bg-white rounded-circle d-inline-flex align-items-center justify-content-center">
                                <span class="text-primary fw-bold fs-4">
                                    {{ user.firstname|first|upper }}{{ user.lastname|first|upper }}
                                </span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Informations de session -->
        <div class="row">
            <div class="col-12">
                <div class="card">
                    <div class="card-header">
                        <h5 class="card-title mb-0">
                            <i class="fas fa-info-circle me-2"></i>
                            Informations de session
                        </h5>
                    </div>
                    <div class="card-body">
                        <div class="row">
                            <div class="col-md-6">
                                <p><strong>Nom :</strong> {{ user.firstname }} {{ user.lastname }}</p>
                                <p><strong>Email :</strong> {{ user.email }}</p>
                                <p><strong>Compte activé :</strong>
                                    {% if user.enable %}
                                        <span class="badge bg-success">Oui</span>
                                    {% else %}
                                        <span class="badge bg-danger">Non</span>
                                    {% endif %}
                                </p>
                            </div>
                            <div class="col-md-6">
                                <p><strong>Rôles :</strong></p>
                                <div class="d-flex flex-wrap gap-1">
                                    {% for role in user.roles %}
                                        <span class="badge bg-primary">{{ role }}</span>
                                    {% endfor %}
                                </div>
                                <p class="mt-3"><strong>Dernière connexion :</strong> {{ "now"|date("d/m/Y H:i") }}</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
{% endblock %}
