<form method="post" class="p-4 rounded shadow-sm bg-white">

    <h5 class="mb-4 fw-bold">
        <i class="fas fa-gas-pump text-primary me-1"></i>
        Nouveau jaugeage
    </h5>

    <div class="row g-4">

        <!-- Type carburant -->
        <div class="col-md-6">
            <label class="form-label fw-semibold">
                <i class="fas fa-oil-can me-1 text-primary"></i>
                Type de carburant
            </label>
            <select id="typeCarburant" class="form-select" required>
                <option value="">-- Sélectionner --</option>
                {% for type in typeCarburants %}
                    <option value="{{ type.id }}">{{ type.name|upper }}</option>
                {% endfor %}
            </select>
        </div>

        <!-- Cuve -->
        <div class="col-md-6">
            <label class="form-label fw-semibold">
                <i class="fas fa-database me-1 text-primary"></i>
                Cuve
            </label>
            <select id="cuve" name="cuve" class="form-select" required>
                <option value="">-- Sélectionner une cuve --</option>
            </select>
        </div>

        <!-- Quantité -->
        <div class="col-md-6">
            <label class="form-label fw-semibold">
                <i class="fas fa-ruler-vertical me-1 text-primary"></i>
                Quantité jaugée (cm)
            </label>
            {{ form_widget(form.quantity, {
                attr: { class: 'form-control', placeholder: 'Ex: 120.5' }
            }) }}
        </div>

        <!-- Date -->
        <div class="col-md-6">
            <label class="form-label fw-semibold">
                <i class="fas fa-calendar-alt me-1 text-primary"></i>
                Date du jaugeage
            </label>
            <input type="datetime-local" name="createdAt" class="form-control" required>
        </div>

    </div>

    <div class="text-end mt-4">
        <button class="btn btn-primary px-4">
            <i class="fas fa-save me-1"></i> Enregistrer
        </button>
    </div>

    {{ form_rest(form) }}

</form>
