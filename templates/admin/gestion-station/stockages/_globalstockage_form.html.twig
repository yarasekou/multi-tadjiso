{{ form_start(form, {'attr': {'onsubmit':"return confirm('Êtes-vous sûr(e) ?')"}}) }}

<!-- Type carburant manuel -->
<div class="mb-3">
    <label for="typeCarburant" class="form-label fw-bold">Type de carburant</label>
    <select id="typeCarburant" name="typeCarburant" class="form-control" required>
        <option value="">-- CHOISIR TYPE CARBURANT --</option>
        {% for typeC in typeCarburants %}
            <option value="{{ typeC.id }}">{{ typeC.name|upper }}</option>
        {% endfor %}
    </select>
</div>

<!-- Champs Symfony -->
<div class="mb-3">
    {{ form_label(form.quantity) }}
    {{ form_widget(form.quantity, {'attr': {'class': 'form-control'}}) }}
    {{ form_errors(form.quantity) }}
</div>

<div class="mb-3">
    {{ form_label(form.purchasePrice) }}
    {{ form_widget(form.purchasePrice, {'attr': {'class': 'form-control'}}) }}
    {{ form_errors(form.purchasePrice) }}
</div>

<div class="mb-3">
    {{ form_label(form.missingQuantity) }}
    {{ form_widget(form.missingQuantity, {'attr': {'class': 'form-control'}}) }}
    {{ form_errors(form.missingQuantity) }}
</div>

<!-- Date -->
<div class="mb-3">
    <label for="createdAt" class="form-label fw-bold">Date</label>
    <input type="date" id="createdAt" name="createdAt" class="form-control" required>
</div>

<button type="submit" class="btn btn-primary">Enregistrer</button>

{{ form_end(form) }}
