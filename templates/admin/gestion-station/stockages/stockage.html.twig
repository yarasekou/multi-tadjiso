{% extends 'admin-station.base.html.twig' %}

{% block title %}Gestion des Stockages{% endblock %}

{% block body %}
    <div class="container-fluid py-4">

        <!-- Header -->
        <div class="d-flex justify-content-between align-items-center mb-4">
            <div>
                <h1 class="h3 mb-0 text-uppercase">Gestion des Stockages</h1>
                <p class="text-muted mb-0">Enregistrement et suivi des carburants</p>
            </div>
            <div class="d-flex gap-2">
                <a href="{{ path('admin.station.globalstockages.new', {'id': station.id}) }}" class="btn btn-primary">
                    <i class="fas fa-plus-circle me-1"></i> Nouveau stockage global
                </a>
                <a href="{{ path('admin.stations') }}" class="btn btn-outline-secondary">
                    <i class="fas fa-arrow-left me-1"></i> Retour
                </a>
            </div>
        </div>

        <!-- Flash Messages -->
        {% for type in ['success', 'danger'] %}
            {% for message in app.flashes(type) %}
                <div class="alert alert-{{ type }} alert-dismissible fade show" role="alert">
                    <i class="fas fa-{{ type == 'success' ? 'check-circle' : 'exclamation-triangle' }} me-2"></i>{{ message }}
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            {% endfor %}
        {% endfor %}

        <!-- Formulaire stockage global -->
        <div class="card mb-4 shadow-sm">
            <div class="card-header bg-primary text-white">
                <h5 class="mb-0"><i class="fas fa-gas-pump me-2"></i>Enregistrer un Stockage Global</h5>
            </div>
            <div class="card-body">
                <div class="alert alert-info text-uppercase fw-bold text-center mb-4">
                    Vous devez enregistrer le <strong>Stockage Global</strong> avant celui des cuves
                </div>
                {{ include('admin/gestion-station/stockages/_stockage_form.html.twig') }}
            </div>
        </div>

        <!-- Stockages par cuve -->
        {% if stockages is defined %}
            <div class="card mb-4 shadow-sm">
                <div class="card-header bg-success text-white">
                    <h5 class="mb-0"><i class="fas fa-database me-2"></i>Stockages par Cuve</h5>
                </div>
                <div class="card-body table-responsive">
                    <table class="table table-hover table-striped align-middle text-center">
                        <thead class="table-dark">
                        <tr>
                            <th>Cuve</th>
                            <th>Quantité</th>
                            <th>Manquant</th>
                            <th>Date</th>
                            <th>Prix U.</th>
                            <th>Action</th>
                        </tr>
                        </thead>
                        <tbody>
                        {% for stock in stockages %}
                            <tr>
                                <td><span class="badge bg-info">{{ stock.cuve.code }}</span></td>
                                <td><span class="badge bg-warning">{{ stock.quantity|number_format }} L</span></td>
                                <td><span class="badge bg-danger">{{ stock.missingQuantity }} L</span></td>
                                <td><span class="badge bg-success">{{ stock.createdAt|date('d/m/Y') }}</span></td>
                                <td><span class="badge bg-primary">{{ stock.purchasePrice }} FCFA</span></td>
                                <td class="text-nowrap">
                                    {% if stock.isLast %}
                                        <a href="#" class="btn btn-sm btn-warning">
                                            <i class="fas fa-edit"></i>
                                        </a>
                                    {% else %}
                                        <button class="btn btn-sm btn-secondary" disabled>
                                            <i class="fas fa-lock"></i>
                                        </button>
                                    {% endif %}
                                </td>
                            </tr>
                        {% endfor %}
                        </tbody>
                    </table>
                    <div class="mt-3 d-flex justify-content-end">
                        {{ knp_pagination_render(stockages) }}
                    </div>
                </div>
            </div>
        {% endif %}

        <!-- Stockages globaux -->
        {% if stockageGlobals is defined %}
            <div class="card mb-4 shadow-sm">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0"><i class="fas fa-gas-pump me-2"></i>Stockages Globaux</h5>
                </div>
                <div class="card-body table-responsive">
                    <table class="table table-bordered table-striped text-center align-middle">
                        <thead class="table-dark">
                        <tr>
                            <th>Carburant</th>
                            <th>Quantité</th>
                            <th>Date</th>
                            <th>Manquant</th>
                            <th>Prix Achat</th>
                            <th>Action</th>
                        </tr>
                        </thead>
                        <tbody>
                        {% for stockageG in stockageGlobals %}
                            <tr>
                                <td><span class="badge bg-secondary">{{ stockageG.typeCarburant.name|upper }}</span></td>
                                <td><span class="badge bg-danger">{{ stockageG.quantity|number_format }} L</span></td>
                                <td><span class="badge bg-success">{{ stockageG.createdAt|date('d/m/Y') }}</span></td>
                                <td><span class="badge bg-dark">{{ stockageG.missingQuantity }} L</span></td>
                                <td><span class="badge bg-info">{{ stockageG.purchasePrice }} FCFA</span></td>
                                <td class="text-nowrap">
                                    <div class="btn-group gap-1">
                                        <a href="#" class="btn btn-sm btn-warning"><i class="fas fa-edit"></i></a>
                                        <form method="post" action="#" onsubmit="return confirm('Confirmer la suppression ?');">
                                            <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ stockageG.id) }}">
                                            <button class="btn btn-sm btn-outline-danger"><i class="fas fa-trash"></i></button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        {% endfor %}
                        </tbody>
                    </table>
                </div>
            </div>
        {% endif %}

    </div>
{% endblock %}
{% block javascripts %}
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const typeCarburant = document.getElementById('typeCarburant');
            const cuveSelect = document.getElementById('cuve');

            typeCarburant.addEventListener('change', function() {
                const typeId = this.value;
                cuveSelect.innerHTML = '<option value="">-- SELECTIONNER UNE CUVE DE STOCKAGE --</option>';

                if(typeId) {
                    fetch('/get-cuves-by-type-carburant/' + typeId)
                        .then(response => response.json())
                        .then(data => {
                            data.forEach(cuve => {
                                console.log(cuve);
                                const option = document.createElement('option');
                                option.value = cuve.id;
                                option.textContent = cuve.numero;
                                cuveSelect.appendChild(option);
                            });
                        })
                        .catch(err => console.error('Erreur: ', err));
                }
            });
        });
    </script>

{% endblock %}
