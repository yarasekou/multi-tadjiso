{% extends 'admin-station.base.html.twig' %}

{% block title %}Gestion des Stockages{% endblock %}

{% block page_title %}Gestion des Stockages{% endblock %}
{% block breadcrumb %}
    <li class="breadcrumb-item"><a href="{{ path('admin.dashboard') }}">Dashboard</a></li>
    <li class="breadcrumb-item"><a href="{{ path('admin.stations') }}">Stations</a></li>
    <li class="breadcrumb-item active">Stockages</li>
{% endblock %}
{% block body %}
    <div class="container-fluid">

        <!-- Header -->
        <div class="d-flex justify-content-between align-items-center mb-4">
            <div>
                <h1 class="h3 mb-0 text-uppercase">Gestion des Stockages</h1>
                <p class="text-muted mb-0">Enregistrement et suivi des carburants</p>
            </div>
            <a href="{{ path('admin.stations') }}" class="btn btn-outline-secondary">
                <i class="fas fa-arrow-left me-1"></i> Retour
            </a>
        </div>

        <!-- Flash Messages -->
        {% for message in app.flashes('success') %}
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                <i class="fas fa-check-circle me-2"></i>{{ message }}
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        {% endfor %}
        {% for message in app.flashes('danger') %}
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                <i class="fas fa-exclamation-triangle me-2"></i>{{ message }}
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        {% endfor %}

        <!-- Enregistrement du stockage cuves -->
        <div class="card mb-4">
            <div class="card-header bg-info text-white">
                <h5 class="card-title mb-0"><i class="fas fa-plus me-2"></i>Enregistrer un Stockage</h5>
            </div>
            <div class="card-body">
                <div class="alert alert-primary text-uppercase fw-bold text-center mb-4">
                    Vous devez enregistrer le <strong>Stockage Global</strong> avant celui des cuves
                </div>

                {{ include('admin/gestion-station/stockages/_form-add.html.twig') }}
            </div>
        </div>

        {% if stockages is defined %}
            <!-- Stockages cuves -->
            <div class="card mb-4">
                <div class="card-header bg-success text-white">
                    <h5 class="card-title mb-0"><i class="fas fa-database me-2"></i>Stockages par Cuve</h5>
                </div>
                <div class="card-body">
                    <div class="table-responsive">
                        <table class="table table-hover align-middle text-center">
                            <thead class="table-dark">
                            <tr>
                                <th>Cuve</th>
                                <th>Quantité</th>
                                <th>Manquant</th>
                                <th>Date</th>
                                <th>Prix U.</th>
                                <th>Action</th>
                            </tr>
                            </thead>
                            <tbody>
                            {% for stock in stockages %}
                                <tr>
                                    <td><span class="badge bg-info">{{ stock.cuve.numero }}</span></td>
                                    <td><span class="badge bg-dark">{{ stock.quantity|number_format }} L</span></td>
                                    <td><span class="badge bg-danger">{{ stock.manquant }} L</span></td>
                                    <td><span class="badge bg-success">{{ stock.createdAt|date('d/m/Y') }}</span></td>
                                    <td><span class="badge bg-primary">{{ stock.prixUnitaire }} FCFA</span></td>
                                    <td>
                                        {% if stock.isLast %}
                                            <a href="{{ path('gestion_stockages.edit', {'id': stock.id}) }}"
                                               class="btn btn-sm btn-warning">
                                                <i class="fas fa-edit"></i>
                                            </a>
                                        {% else %}
                                            <button class="btn btn-sm btn-secondary" disabled>
                                                <i class="fas fa-lock"></i>
                                            </button>
                                        {% endif %}
                                    </td>
                                </tr>
                            {% endfor %}
                            </tbody>
                        </table>
                        <div class="mt-3">{{ knp_pagination_render(stockages) }}</div>
                    </div>
                </div>
            </div>
        {% endif %}

        {% if stockageGlobals is defined %}
            <!-- Stockages globaux -->
            <div class="card mb-4">
                <div class="card-header bg-primary text-white">
                    <h5 class="card-title mb-0"><i class="fas fa-gas-pump me-2"></i>Stockages Globaux</h5>
                </div>
                <div class="card-body">
                    <div class="table-responsive">
                        <table class="table table-bordered text-center align-middle">
                            <thead class="table-dark">
                            <tr>
                                <th>Carburant</th>
                                <th>Quantité</th>
                                <th>Date</th>
                                <th>Manquant</th>
                                <th>Prix Achat</th>
                                <th>Action</th>
                            </tr>
                            </thead>
                            <tbody>
                            {% for stockageG in stockageGlobals %}
                                <tr>
                                    <td><span class="badge bg-secondary">{{ stockageG.typeCarburant.name|upper }}</span></td>
                                    <td><span class="badge bg-danger">{{ stockageG.quantite|number_format }} L</span></td>
                                    <td><span class="badge bg-success">{{ stockageG.createdAt|date('d/m/Y') }}</span></td>
                                    <td><span class="badge bg-dark">{{ stockageG.manquant }} L</span></td>
                                    <td><span class="badge bg-info">{{ stockageG.prixAchat }} FCFA</span></td>
                                    <td>
                                        <div class="btn-group gap-1">
                                            <a href="{{ path('gestion_stockages.editGlobalStockage', {'id': stockageG.id}) }}"
                                               class="btn btn-sm btn-warning"><i class="fas fa-edit"></i></a>
                                            <form method="post"
                                                  action="{{ path('gestion_stockages.deleteGlobalStockage', {'id': stockageG.id}) }}"
                                                  onsubmit="return confirm('Confirmer la suppression ?');">
                                                <input type="hidden" name="_token"
                                                       value="{{ csrf_token('delete' ~ stockageG.id) }}">
                                                <button class="btn btn-sm btn-outline-danger"><i class="fas fa-trash"></i></button>
                                            </form>
                                        </div>
                                    </td>
                                </tr>
                            {% endfor %}
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        {% endif %}

        <!-- Bouton modale -->
        <div class="text-end">
            <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#modalGlobalStockage">
                + Stockage Global
            </button>
        </div>
    </div>
{% endblock %}
{% block javascripts %}
    <script>
        $(".alert").delay(5000).slideUp(200, function () {
            $(this).alert('close'); });
        let typeCarburant = $('#stockage_single_typeCarburant');
        let cuveStockage = $('#stockage_cuve');
        $(document).ready(function () {
            typeCarburant.val('');
            cuveStockage.empty();
        });
        typeCarburant.on('change', function (e) {
            let id = e.target.value; if (id !== '') {
                loadCuves(id); cuveStockage.empty();
            }
        });
        function loadCuves(typeId) {
            $.ajax({
                url: '/get-cuves-by-type-carburant/' + typeId,
                type: 'get',
                dataType: 'json',
                success: function (data) {
                    cuveStockage.empty().append(
                        $('<option>', {
                            value: '',
                            text: "-- SELECTIONNER LA CUVE DE STOCKAGE --" }));
                    $.each(data, function (index, cuve) {
                        cuveStockage.append($('<option>', {
                            value: cuve['id'], text: cuve['numero'] }));
                    });
                    },
                error: function (error) {
                    console.log('error ==> ' + error)
                }
            });
        }
    </script>
{% endblock %}
