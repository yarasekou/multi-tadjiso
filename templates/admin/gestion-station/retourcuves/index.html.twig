{% extends 'admin-station.base.html.twig' %}

{% block body %}
    <div class="container mt-4">

        <h3 class="mb-4 fw-bold">
            <i class="fas fa-gas-pump text-primary me-2"></i>
            Retours en cuve – <strong>{{ station.name }}</strong>
        </h3>

        {# ALERTES #}
        {% for label, messages in app.flashes %}
            {% for msg in messages %}
                <div class="alert alert-{{ label }} alert-dismissible fade show">
                    {{ msg }}
                    <button class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            {% endfor %}
        {% endfor %}

        <div class="row">
            <div class="col-lg-4">

                <div class="card shadow-sm">
                    <div class="card-body">

                        <h5 class="fw-bold mb-3">
                            <i class="fas fa-plus-circle text-success me-1"></i>
                            Nouveau retour
                        </h5>

                        <form method="post">

                            <div class="mb-3">
                                <label class="form-label fw-semibold">
                                    Type carburant
                                </label>
                                <select name="typeCarburant" class="form-select" required>
                                    <option value="">-- Sélectionner --</option>
                                    {% for type in typeCarburants %}
                                        <option value="{{ type.id }}">
                                            {{ type.name|upper }}
                                        </option>
                                    {% endfor %}
                                </select>
                            </div>

                            <div class="mb-3">
                                <label class="form-label">Quantité (L)</label>
                                {{ form_widget(form.quantity, { attr: { class: 'form-control' } }) }}
                            </div>

                            <div class="mb-3">
                                <label class="form-label">Date</label>
                                <input type="datetime-local" name="createdAt" class="form-control" required>
                            </div>

                            <button class="btn btn-success w-100">
                                <i class="fas fa-save me-1"></i> Enregistrer
                            </button>

                            {{ form_rest(form) }}
                        </form>

                    </div>
                </div>

            </div>

            <div class="col-lg-8">
                <div class="card shadow-sm">
                    <div class="card-body">

                        <h5 class="fw-bold mb-3">
                            <i class="fas fa-list me-1"></i> Historique des retours
                        </h5>

                        <table class="table table-bordered align-middle">
                            <thead class="table-light">
                            <tr>
                                <th>Type Carburant</th>
                                <th>Quantité</th>
                                <th>Date</th>
                                <th class="text-center">Actions</th>
                            </tr>
                            </thead>
                            <tbody>
                            {% for retour in retourEnCuves %}
                                <tr>
                                    <td>{{ retour.typeCarburant.name|upper }}</td>
                                    <td>{{ retour.quantity }} L</td>
                                    <td>{{ retour.createdAt|date('d/m/Y H:i') }}</td>
                                    <td class="text-center">
                                        <a href="{{ path('admin.station.retourcuves.edit', {'id': station.id, 'retourcuveId': retour.id}) }}"
                                           class="btn btn-primary btn-sm">
                                            <i class="fas fa-edit"></i>
                                        </a>

                                        <form method="post"
                                              action="{{ path('admin.station.retourcuves.delete', {'id': station.id, 'retourcuveId': retour.id}) }}"
                                              style="display:inline-block"
                                              onsubmit="return confirm('Supprimer ce retour ?');">
                                            <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ retour.id) }}">
                                            <button class="btn btn-danger btn-sm">
                                                <i class="fas fa-trash-alt"></i>
                                            </button>
                                        </form>

                                    </td>
                                </tr>
                            {% else %}
                                <tr>
                                    <td colspan="4" class="text-center text-muted">
                                        Aucun retour enregistré
                                    </td>
                                </tr>
                            {% endfor %}
                            </tbody>
                        </table>

                        <div class="mt-3">
                            {{ knp_pagination_render(retourEnCuves) }}
                        </div>

                    </div>
                </div>
            </div>
        </div>
    </div>
{% endblock %}
