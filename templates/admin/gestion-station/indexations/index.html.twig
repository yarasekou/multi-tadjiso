{% extends 'admin-station.base.html.twig' %}

{% block title %}Gestion des index - {{ station.name }}{% endblock %}

{% block body %}
    <div class="container-fluid py-4">

        <!-- Header -->
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h3 class="text-uppercase fw-bold">Gestion des index des pistolets</h3>
            <a href="{{ path('admin.stations') }}" class="btn btn-outline-secondary">
                <i class="fas fa-arrow-left me-1"></i> Retour
            </a>
        </div>

        <!-- Flash Messages -->
        {% for type in ['success', 'danger'] %}
            {% for message in app.flashes(type) %}
                <div class="alert alert-{{ type }} alert-dismissible fade show text-uppercase fw-bold" role="alert">
                    <i class="fas fa-{{ type == 'success' ? 'check-circle' : 'exclamation-triangle' }} me-2"></i>{{ message }}
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            {% endfor %}
        {% endfor %}

        <!-- Formulaire d'indexation -->
        <div class="card shadow-sm mb-4">
            <div class="card-header bg-primary text-white">
                <h5 class="mb-0"><i class="fas fa-plus me-2"></i>Nouvel index</h5>
            </div>
            <div class="card-body">
                {{ include('admin/gestion-station/indexations/_form.html.twig') }}
            </div>
        </div>

        <!-- Historique des index -->
        <div class="card shadow-sm">
            <div class="card-header bg-dark text-white d-flex justify-content-between align-items-center">
                <h5 class="mb-0"><i class="fas fa-list me-2"></i>Historique des index</h5>
                <button class="btn btn-outline-success btn-sm" data-bs-toggle="modal" data-bs-target="#indexParDate">
                    Index par date
                </button>
            </div>
            <div class="card-body table-responsive">
                {% if indexations is defined and indexations|length != 0 %}
                    <table class="table table-striped table-hover text-center align-middle">
                        <thead class="table-dark text-uppercase">
                        <tr>
                            <th>Index</th>
                            <th>Litres</th>
                            <th>Pistolet</th>
                            <th>Date</th>
                            <th>Action</th>
                        </tr>
                        </thead>
                        <tbody>
                        {% for indexation in indexations %}
                            <tr>
                                <td><span class="badge bg-info text-uppercase">{{ indexation.valIndex|format_number }}</span></td>
                                <td><span class="badge bg-success">{{ indexation.difference|format_number }} L</span></td>
                                <td><span class="badge bg-dark">{{ indexation.pistolet.pompe.code }} {{ indexation.pistolet.code }}</span></td>
                                <td><span class="badge bg-danger">{{ indexation.createdAt|date('d-m-Y') }}</span></td>
                                <td>
                                    <a href="#" class="btn btn-warning btn-sm"><i class="fas fa-edit"></i></a>
                                </td>
                            </tr>
                        {% endfor %}
                        </tbody>
                    </table>
                    <div class="d-flex justify-content-end">{{ knp_pagination_render(indexations) }}</div>
                {% else %}
                    <div class="alert alert-danger text-center text-uppercase fw-bold">Pas d'enregistrement trouvé</div>
                {% endif %}
            </div>
        </div>

    </div>

    <!-- Modal Index par date -->
    <div class="modal fade" id="indexParDate" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header bg-primary text-white">
                    <h5 class="modal-title fw-bold">Index des pistolets par date</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <form method="POST" onsubmit="return confirm('Êtes-vous sûr(e) ?')" action="{{ path('admin.station.indexations', {'id': station.id}) }}" class="p-3 text-uppercase fw-bold">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label for="dateInf" class="form-label">Date inférieure</label>
                            <input type="date" class="form-control" name="dateInf" id="dateInf" required>
                        </div>
                        <div class="col-md-6">
                            <label for="dateSup" class="form-label">Date supérieure</label>
                            <input type="date" class="form-control" name="dateSup" id="dateSup" required>
                        </div>
                    </div>
                    <div class="mt-3 text-end">
                        <button type="submit" name="btnIndexByDate" value="1" class="btn btn-outline-primary">Envoyer</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

{% endblock %}

{% block javascripts %}
    <script>
        $(document).ready(function() {
            let typeCarburant = $('#stockage_single_typeCarburant');
            let cuveStockage = $('#stockage_cuve');

            typeCarburant.on('change', function() {
                let id = $(this).val();
                if (id !== '') {
                    cuveStockage.empty().append('<option value="">Chargement...</option>');
                    $.ajax({
                        url: '/get-pistolets-by-typeCarburant/' + id,
                        type: 'GET',
                        dataType: 'json',
                        success: function(data) {
                            cuveStockage.empty().append('<option value="">-- Sélectionner un pistolet --</option>');
                            data.forEach(pistolet => {
                                cuveStockage.append(`<option value="${pistolet.id}">${pistolet.numero}</option>`);
                            });
                        },
                        error: function(err) {
                            console.error(err);
                            cuveStockage.empty().append('<option value="">Erreur</option>');
                        }
                    });
                } else {
                    cuveStockage.empty().append('<option value="">-- Sélectionner un pistolet --</option>');
                }
            });
        });
    </script>
{% endblock %}
